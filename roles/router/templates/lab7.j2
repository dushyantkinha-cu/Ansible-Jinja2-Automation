hostname {{ item.hostname }}
!
! --- Interface Configuration ---
{% for intf in item.interfaces %}
interface {{ intf.type }}{{ intf.name }}
 ip address {{ intf.ip }} {{ intf.mask }}
{% if intf.type == 'GigabitEthernet' %}
 duplex auto
 speed auto
 no shutdown
{% endif %}
!
{% endfor %}
!
! --- OSPF Configuration ---
router ospf {{ item.ospf_process }}
 log-adjacency-changes
{% for intf in item.interfaces %}
{% if intf.ospf_enabled %}
 network {{ intf.ospf_network }} {{ intf.ospf_wildcard }} area {{ intf.ospf_area }}
{% endif %}
{% endfor %}
!
